{
  "name": "simple-storybook-preview-mcp",
  "version": "1.0.1",
  "description": "MCP server that renders Storybook component previews inside the IDE",
  "type": "module",
  "bin": {
    "simple-storybook-preview-mcp": "./dist/server.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/matipojo/simple-storybook-preview-mcp.git"
  },
  "homepage": "https://github.com/matipojo/simple-storybook-preview-mcp",
  "bugs": {
    "url": "https://github.com/matipojo/simple-storybook-preview-mcp/issues"
  },
  "files": [
    "dist",
    "static/storybook.html",
    "static/storybook.css",
    "static/debug.css"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/server.js && esbuild static/app-entry.ts --bundle --format=iife --platform=browser --outfile=dist/mcp-app-bundle.js --minify",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "storybook",
    "preview",
    "model-context-protocol",
    "cursor"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.1.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.3",
    "shx": "^0.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
